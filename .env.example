# Host the HTTP server should bind to.
# Use 0.0.0.0 for Render and most cloud deployments.
# Use 127.0.0.1 locally if you only want local machine access.
APP_HOST=0.0.0.0

# Port the HTTP server should listen on.
# Render provides PORT automatically; APP_PORT is mainly for local use.
APP_PORT=4000

# PostgreSQL connection URL.
# For Aiven, keep sslmode=require at the end.
DATABASE_URL=postgres://username:password@host:port/database_name?sslmode=require

# Secret used later for JWT authentication.
# Replace this with a strong private value in production.
JWT_SECRET=change-me

# JWT lifetime in seconds.
JWT_EXPIRES_IN_SECONDS=86400

# Upload storage configuration.
# Use local for development.
STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=storage
MAX_UPLOAD_BYTES=10485760

# Backblaze B2 S3-compatible storage configuration.
# Use these when STORAGE_PROVIDER=backblaze.
BACKBLAZE_BUCKET=korede-kyc-documents
BACKBLAZE_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
BACKBLAZE_ACCESS_KEY_ID=your-backblaze-key-id
BACKBLAZE_SECRET_ACCESS_KEY=your-backblaze-application-key
BACKBLAZE_REGION=eu-central-003

# Transactional email configuration.
# Use disabled locally when you do not want to send real emails.
# Use resend or brevo when you are ready to send real emails.
EMAIL_PROVIDER=disabled
EMAIL_FROM_ADDRESS=no-reply@your-domain.com
EMAIL_FROM_NAME="Korede Health"
BREVO_API_KEY=your-brevo-api-key
RESEND_API_KEY=your-resend-api-key

# Sui blockchain proof configuration.
# Testnet is the default target for development.
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_PACKAGE_ID=
SUI_ADMIN_ADDRESS=
SUI_KEYSTORE_PATH=/path/to/sui.keystore
SUI_GAS_BUDGET=10000000

# Payment provider secrets.
# Leave blank until these providers are integrated.
APP_NAME="Korede Health"
APP_BASE_URL=http://127.0.0.1:4000
PAYSTACK_SECRET_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_DVA_PREFERRED_BANK=test-bank
PAYSTACK_DVA_COUNTRY=NG
FLUTTERWAVE_SECRET_KEY=

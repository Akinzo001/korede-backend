# Host the HTTP server should bind to.
# Use 127.0.0.1 for local development.
# Use 0.0.0.0 for most cloud deployments.
APP_HOST=127.0.0.1

# Port the HTTP server should listen on.
APP_PORT=4000

# PostgreSQL connection URL.
# For Aiven, keep sslmode=require at the end.
DATABASE_URL=postgres://username:password@host:port/database_name?sslmode=require

# Secret used later for JWT authentication.
# Replace this with a strong private value in production.
JWT_SECRET=change-me

# Solana RPC endpoint.
# Devnet is safe for development.
SOLANA_RPC_URL=https://api.devnet.solana.com

# Deployed Korede donations Anchor program ID.
# Fill this after deploying the program to Devnet.
SOLANA_PROGRAM_ID=your-devnet-program-id

# Local path to the Solana authority keypair used by backend workers later.
# Never commit the actual keypair file.
SOLANA_AUTHORITY_KEYPAIR_PATH=/path/to/devnet-authority.json

# Payment provider secrets.
# Leave blank until these providers are integrated.
PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=

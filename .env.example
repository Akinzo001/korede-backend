# Host the HTTP server should bind to.
# Use 127.0.0.1 for local development.
# Use 0.0.0.0 for most cloud deployments.
APP_HOST=127.0.0.1

# Port the HTTP server should listen on.
APP_PORT=4000

# PostgreSQL connection URL.
# For Aiven, keep sslmode=require at the end.
DATABASE_URL=postgres://username:password@host:port/database_name?sslmode=require

# Secret used later for JWT authentication.
# Replace this with a strong private value in production.
JWT_SECRET=change-me

# JWT lifetime in seconds.
JWT_EXPIRES_IN_SECONDS=86400

# Upload storage configuration.
# Use local for development.
STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=storage
MAX_UPLOAD_BYTES=10485760

# Cloudflare R2 storage configuration.
# Fill these when STORAGE_PROVIDER is changed to r2 after the R2 adapter is implemented.
R2_BUCKET=korede-kyc-documents
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_REGION=auto

# Sui blockchain proof configuration.
# Testnet is the default target for development.
SUI_NETWORK=testnet
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
SUI_PACKAGE_ID=
SUI_ADMIN_ADDRESS=
SUI_KEYSTORE_PATH=/path/to/sui.keystore
SUI_GAS_BUDGET=10000000

# Payment provider secrets.
# Leave blank until these providers are integrated.
PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=
